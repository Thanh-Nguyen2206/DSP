.DS_Store
__pycache__/
*.py[cod]
*.so

# Local Gradio/runtime files
.gradio/
outputs/

# Environment and secrets
.env
.venv/
venv/
env/

# Large or private training artifacts
checkpoints/**
!checkpoints/
!checkpoints/.gitkeep
!checkpoints/experiments/
!checkpoints/experiments/.gitkeep

logs/**
!logs/
!logs/.gitkeep
!logs/experiments/
!logs/experiments/.gitkeep

data/raw/**
!data/raw/
!data/raw/.gitkeep

data/processed/**
!data/processed/
!data/processed/.gitkeep

data/metadata/**
!data/metadata/
!data/metadata/.gitkeep

# Model/audio files that should not be committed accidentally
*.pt
*.pth
*.ckpt
*.safetensors
*.wav
*.mp3
*.flac
*.aiff
*.m4a

# Keep evaluation templates, but ignore generated reports unless explicitly added.
evaluation/best_model.json
evaluation/best_model_report.md
